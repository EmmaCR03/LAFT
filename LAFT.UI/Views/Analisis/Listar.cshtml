@model IEnumerable<LAFT.Abstracciones.Modelos.Analisis.PersonaAnalizadaDto>

@{
    ViewBag.Title = "Análisis de personas";
}

<h2>Personas con análisis registrado</h2>
<p class="text-muted">Solo aparecen personas que ya tienen al menos un análisis en base de datos. Para generar uno nuevo, use <strong>Analizar</strong> desde el listado de personas.</p>

@if (Model == null || !Model.Any())
{
    <p>No hay análisis para mostrar. Registre personas y ejecute un análisis desde @Html.ActionLink("Personas", "IndexPersona", "Persona").</p>
}
else
{

<table class="table table-dark table-striped table-hover">
    <tr>
       
        <th>
            @Html.DisplayNameFor(model => model.TipoIdentificacion)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.NombrePersona)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.PrimerApellidoPersona)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.SegundoApellidoPersona)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.NivelDeRiesgoGenerado)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.FechaDeAnalisis)
        </th>
        <th>Acciones</th>
    </tr>

@foreach (var item in Model) {
    <tr>
        
        <td>
            @Html.DisplayFor(modelItem => item.TipoIdentificacion)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.NombrePersona)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.PrimerApellidoPersona)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.SegundoApellidoPersona)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.NivelDeRiesgoGenerado)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.FechaDeAnalisis)
        </td>
        <td>
            @Html.ActionLink("Ver historial", "ListarPorId", "Analisis", new { idPersona = item.IdPersona }, new { @class = "btn btn-sm btn-outline-info" })
        </td>
    </tr>
}

</table>
}
