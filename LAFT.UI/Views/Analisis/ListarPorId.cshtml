@model IEnumerable<LAFT.Abstracciones.Modelos.Analisis.AnalisisDTO>

@{
    ViewBag.Title = "Historial de análisis";
}

<h2>Historial de análisis por persona</h2>

<p>
    @Html.ActionLink("← Volver al listado de análisis", "Listar", "Analisis", null, new { @class = "btn btn-outline-secondary btn-sm" })
    &nbsp;
    @Html.ActionLink("Ir a personas", "IndexPersona", "Persona", null, new { @class = "btn btn-outline-light btn-sm" })
</p>

@if (Model == null || !Model.Any())
{
    <p>No hay registros de análisis para esta persona.</p>
}
else
{
<table class="table table-dark table-striped table-hover">
    <tr>
        <th>
            @Html.DisplayNameFor(model => model.IdAnalisis)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.IdPersona)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.NivelDeRiesgoGenerado)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.TotalDePalabrasClaveEncontradas)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.CantidadDeArchivosEmparejados)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.FechaDeAnalisis)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.Comentario)
        </th>
    </tr>

@foreach (var item in Model)
{
    <tr>
        <td>
            @Html.DisplayFor(modelItem => item.IdAnalisis)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.IdPersona)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.NivelDeRiesgoGenerado)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.TotalDePalabrasClaveEncontradas)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.CantidadDeArchivosEmparejados)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.FechaDeAnalisis)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.Comentario)
        </td>
    </tr>
}

</table>
}
